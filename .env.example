# Local dev environment — copy to .env and adjust as needed.
# .env is git-ignored; secrets never go in the repo (prod uses Secret Manager).

# PostgreSQL (docker-compose local dev)
POSTGRES_USER=hpt
POSTGRES_PASSWORD=hpt
POSTGRES_DB=hpt
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hpt:hpt@localhost:5432/hpt

# API
PORT=3000

# Auth (lot 1.1) — JWT access/refresh. Secrets DEV uniquement : en prod ils
# viennent du Secret Manager (Stack §3.5), jamais du dépôt. Access ~15 min,
# refresh ~30 j (durées codées dans auth.config.ts, ajustables).
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Vérification e-mail & reset (lot 1.2) — base des liens d'action posés dans les
# e-mails (vérification, réinitialisation). En dev les e-mails sont stubés/loggés
# (ConsoleMailer) ; en prod, TEM (Stack §3.5). Défaut : http://localhost:3000.
APP_PUBLIC_URL=http://localhost:3000

# Abonnement & Mollie (lot 4.2) — upgrade in-app. Montants PARAMÉTRABLES (jamais
# en dur) ; en prod ils sont décidés côté business. MOLLIE_API_KEY vient du
# Secret Manager (Stack §3.5) ; en mode TEST elle commence par « test_ ». SANS
# clé, l'API bascule sur l'adaptateur fake (webhooks simulables localement).
# RGPD : seul l'e-mail du compte est transmis à Mollie (jamais de donnée cheval).
MOLLIE_API_KEY=
SUBSCRIPTION_CURRENCY=EUR
SUBSCRIPTION_INTERVAL=1 month
SUBSCRIPTION_PREMIUM_AMOUNT=9.99
SUBSCRIPTION_PRO_AMOUNT=19.99
# URL publique où Mollie poste l'id de paiement (autorité du tier).
MOLLIE_WEBHOOK_URL=http://localhost:3000/webhooks/mollie
# Deep link de retour de l'app après checkout (doit matcher le scheme app `hpt`).
MOLLIE_REDIRECT_URL=hpt://upgrade-return
# Espace de gestion Mollie (renvoi gérer/résilier, Spec §9.3) ; vide = masqué.
MOLLIE_BILLING_URL=

# Assistant IA — bilan augmenté (lot 4.5, Stack §3.6). MISTRAL_API_KEY vient du
# Secret Manager en prod ; SANS clé, le module bascule sur un STUB déterministe
# (le sandbox de dev n'atteint pas Mistral — consigne). Modèle Mistral Small
# ÉPINGLÉ (jamais `-latest`) : famille + version tracées sur chaque bilan.
# Rate limiting par utilisateur (garde-fou de coût) : nb max de générations par
# fenêtre glissante (une relecture ne consomme rien — get-or-create).
MISTRAL_API_KEY=
AI_BILAN_MODEL=mistral-small
AI_BILAN_MODEL_VERSION=mistral-small-2409
# MISTRAL_BASE_URL=https://api.mistral.ai
AI_BILAN_RATE_LIMIT=10
AI_BILAN_RATE_WINDOW_MS=3600000
