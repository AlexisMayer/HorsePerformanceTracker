# Local dev environment — copy to .env and adjust as needed.
# .env is git-ignored; secrets never go in the repo (prod uses Secret Manager).

# PostgreSQL (docker-compose local dev)
POSTGRES_USER=hpt
POSTGRES_PASSWORD=hpt
POSTGRES_DB=hpt
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hpt:hpt@localhost:5432/hpt

# API
PORT=3000
